# API Base URL for Admin Frontend
# For local development, leave it empty to use the Vite dev server proxy (which proxies /api to http://localhost:5000)
# For production, set it to the URL of the deployed backend (e.g., https://ubackend-guk8.onrender.com)
VITE_API_BASE_URL=https://ubackend-guk8.onrender.com
